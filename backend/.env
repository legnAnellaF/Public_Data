WEATHER_API_BASE_URL=
ECONOMY_API_BASE_URL=
ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173,http://127.0.0.1:5500,http://localhost:5500
